{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sourcedataset",
						"type": "DatasetReference"
					},
					"name": "source"
				},
				{
					"dataset": {
						"referenceName": "sourcedataset",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText1",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "exists1"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as integer,",
				"          created_date as date,",
				"          canceled_date as date,",
				"          subscription_cost as short,",
				"          subscription_interval as string,",
				"          was_subscription_paid as boolean",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     dateFormats: ['yyyy-MM-dd']) ~> source",
				"source(output(",
				"          customer_id as integer,",
				"          created_date as date,",
				"          canceled_date as date,",
				"          subscription_cost as short,",
				"          subscription_interval as string,",
				"          was_subscription_paid as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 10,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source, source2 exists(source@customer_id == source2@customer_id,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists1",
				"exists1 aggregate(groupBy(customer_id,",
				"          created_date,",
				"          subscription_cost),",
				"     count = count(customer_id)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}